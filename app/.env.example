# =============================================================================
# Capital Manager - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# This file is safe to commit — it contains no secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard -> your project -> Settings -> API
# -----------------------------------------------------------------------------

# Public URL — safe to expose, needed by browser client and server
NEXT_PUBLIC_SUPABASE_URL=

# Anon key — safe to expose (RLS enforced), used by browser client + proxy auth
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key (service_role) — found in Supabase dashboard under Settings → API → "secret".
# Server-only, bypasses RLS. Never expose to the browser.
SUPABASE_SECRET_KEY=

# -----------------------------------------------------------------------------
# AI Providers — server-side only, never exposed to browser
# Anthropic: https://console.anthropic.com/settings/keys
# Google AI:  https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# -----------------------------------------------------------------------------
# Database (for running seed script from CLI)
# Settings → Database → Connection string → URI
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
